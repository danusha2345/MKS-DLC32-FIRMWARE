# === Tooling / IDE — не относится к прошивке ===
.claude/
.gitnexus/
.vscode/
.idea/

# === PlatformIO build artifacts ===
.pio/
# Сгенерированный PlatformIO препроцессинг .ino (с абсолютными путями) — не коммитить
*.ino.cpp

# === Локальные данные, не для репозитория ===
# Бэкапы заводской прошивки платы
backup/
# Стороннее Android-приложение (нет исходников, 53 МБ)
*.apk
# Скачанные/временные образы прошивок в корне (release/*.bin — отслеживаются)
/*.bin
# Тестовые G-code файлы в корне
/*.gcode
/*.nc
# Единый flash-образ генерируется из release/*.bin (8 МБ) — раздаётся в Release, не в git
release/MKS_DLC32_full_8MB.bin
# Zip-комплект собирается на лету для Release — не в git
release/*.zip

# === Языки / сборщики ===
__pycache__/
*.py[co]
node_modules/

# === ОС / редакторы ===
.DS_Store
Thumbs.db
*.swp
*~
*.log
